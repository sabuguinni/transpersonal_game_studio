class TRANSPERSONALGAME_API UJurassicTerrainPCGSettings : public UPCGSettings
{
    GENERATED_BODY()

public:
    UJurassicTerrainPCGSettings();

    // Terrain generation parameters
    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Terrain", meta = (ClampMin = "0.0001", ClampMax = "0.01"))
    float BaseFrequency = 0.002f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Terrain", meta = (ClampMin = "0.1", ClampMax = "10.0"))
    float BaseAmplitude = 1.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Terrain", meta = (ClampMin = "1", ClampMax = "8"))
    int32 NoiseOctaves = 6;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Terrain", meta = (ClampMin = "0.1", ClampMax = "1.0"))
    float Persistence = 0.5f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Terrain", meta = (ClampMin = "1.0", ClampMax = "10.0"))
    float Lacunarity = 2.0f;

    // Biome influence on terrain
    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Biomes")
    float ForestHeightMultiplier = 0.8f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Biomes")
    float PlainsHeightMultiplier = 0.3f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Biomes")
    float MountainHeightMultiplier = 1.5f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Biomes")
    float SwampHeightMultiplier = 0.1f;

    // River carving parameters
    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Rivers")
    float RiverDepthMultiplier = 0.5f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Rivers")
    float RiverWidthInfluence = 1000.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Rivers")
    int32 RiverSeed = 12345;

#if WITH_EDITOR
