/**
 * PCG Element for Jurassic terrain generation
 */
class TRANSPERSONALGAME_API FJurassicTerrainPCGElement : public IPCGElement
{
    // GENERATED_BODY() removed - not a UObject

public:
    virtual bool ExecuteInternal(FPCGContext* Context) const override;

protected:
    virtual bool IsCacheable(const UPCGSettings* InSettings) const override { return false; }

private:
    // Noise generation functions
    float GeneratePerlinNoise(float X, float Y, int32 Octaves, float Persistence, float Frequency, float Lacunarity) const;
    float GenerateRidgedNoise(float X, float Y, int32 Octaves, float Persistence, float Frequency) const;
    float GenerateBillowNoise(float X, float Y, int32 Octaves, float Persistence, float Frequency) const;
    
    // Biome-specific terrain modifiers
    float ApplyBiomeHeightModification(float BaseHeight, FVector2D Position, const UJurassicTerrainPCGSettings* Settings) const;
    float CalculateRiverInfluence(FVector2D Position, const UJurassicTerrainPCGSettings* Settings) const;
    
    // Utility functions
    float SmoothStep(float Edge0, float Edge1, float X) const;
    float Lerp(float A, float B, float T) const;
};

/**
 * PCG Settings for Jurassic biome distribution
 * Determines biome placement based on elevation, slope, and moisture
 */
UCLASS(BlueprintType, Blueprintable)
class TRANSPERSONALGAME_API UJurassicBiomePCGSettings : public UPCGSettings
{
    GENERATED_BODY()

public:
    UJurassicBiomePCGSettings();

    // Biome distribution parameters
    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Biome Distribution")
    float MoistureNoiseScale = 0.003f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Biome Distribution")
    float TemperatureNoiseScale = 0.002f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Biome Distribution")
    int32 BiomeSeed = 54321;

    // Elevation thresholds for biome placement
    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Elevation Zones")
    float SeaLevel = 0.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Elevation Zones")
    float LowlandThreshold = 100.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Elevation Zones")
    float MidlandThreshold = 300.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Elevation Zones")
    float HighlandThreshold = 600.0f;

    // Slope thresholds
    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Slope Zones")
    float FlatThreshold = 10.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Slope Zones")
    float GentleThreshold = 25.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Slope Zones")
    float SteepThreshold = 45.0f;

    // Water proximity influence
    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Water Influence")
    float RiverInfluenceRadius = 2000.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Water Influence")
    float CoastInfluenceRadius = 5000.0f;

#if WITH_EDITOR
    virtual FText GetDefaultNodeTitle() const override { return FText::FromString(TEXT("Jurassic Biome Distributor")); }
    virtual FLinearColor GetNodeTitleColor() const override { return FLinearColor::Blue; }
#endif

protected:
    virtual TArray<FPCGPinProperties> InputPinProperties() const override;
    virtual TArray<FPCGPinProperties> OutputPinProperties() const override;
    virtual FPCGElementPtr CreateElement() const override;
};

