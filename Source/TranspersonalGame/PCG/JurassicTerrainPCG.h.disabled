/**
 * PCG Settings for Jurassic river generation
 * Creates river networks using flow simulation and erosion patterns
 */
UCLASS(BlueprintType, Blueprintable)
class TRANSPERSONALGAME_API UJurassicRiverPCGSettings : public UPCGSettings
{
    GENERATED_BODY()

public:
    UJurassicRiverPCGSettings();

    // River network parameters
    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "River Network", meta = (ClampMin = "1", ClampMax = "10"))
    int32 MainRiverCount = 3;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "River Network", meta = (ClampMin = "0", ClampMax = "50"))
    int32 TributaryCount = 15;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "River Network", meta = (ClampMin = "100.0", ClampMax = "2000.0"))
    float MainRiverWidth = 800.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "River Network", meta = (ClampMin = "50.0", ClampMax = "500.0"))
    float TributaryWidth = 200.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "River Network", meta = (ClampMin = "50.0", ClampMax = "1000.0"))
    float RiverDepth = 300.0f;

    // Flow simulation parameters
    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Flow Simulation")
    float FlowAccumulation = 0.8f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Flow Simulation")
    float ErosionStrength = 0.5f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Flow Simulation")
    int32 FlowIterations = 100;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Flow Simulation")
    float MinFlowThreshold = 0.1f;

    // River meandering
    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Meandering")
    float MeanderAmplitude = 500.0f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Meandering")
    float MeanderFrequency = 0.001f;

    UPROPERTY(BlueprintReadWrite, EditAnywhere, Category = "Meandering")
    int32 RiverSeed = 98765;

#if WITH_EDITOR
    virtual FText GetDefaultNodeTitle() const override { return FText::FromString(TEXT("Jurassic River Generator")); }
    virtual FLinearColor GetNodeTitleColor() const override { return FLinearColor::Cyan; }
#endif

protected:
    virtual TArray<FPCGPinProperties> InputPinProperties() const override;
    virtual TArray<FPCGPinProperties> OutputPinProperties() const override;
    virtual FPCGElementPtr CreateElement() const override;
};

