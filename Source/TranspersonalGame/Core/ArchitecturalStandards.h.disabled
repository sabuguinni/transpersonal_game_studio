/**
 * LOGGING CATEGORIES:
 * Each system must define its own log category
 */

// System-specific log categories (to be defined by each agent)
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalCore, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalPhysics, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalPerformance, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalWorld, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalEnvironment, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalArchitecture, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalLighting, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalCharacters, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalAnimation, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalAI, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalCombat, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalCrowd, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalQuest, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalNarrative, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalAudio, Log, All);
DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalVFX, Log, All);
// DUPLICATE: DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalQA, Log, All);

/**
 * LOGGING MACROS:
 * Use these macros for consistent logging
 */
#define TRANSPERSONAL_LOG(Category, Verbosity, Format, ...) \
    UE_LOG(LogTranspersonal##Category, Verbosity, TEXT("[%s] ") Format, *GetClass()->GetName(), ##__VA_ARGS__)

#define TRANSPERSONAL_LOG_SYSTEM(SystemName, Verbosity, Format, ...) \
    UE_LOG(LogTranspersonal##SystemName, Verbosity, TEXT("[SYSTEM] ") Format, ##__VA_ARGS__)

#define TRANSPERSONAL_LOG_PERFORMANCE(SystemName, Format, ...) \
    UE_LOG(LogTranspersonalPerformance, Warning, TEXT("[%s] ") Format, TEXT(#SystemName), ##__VA_ARGS__)

#define TRANSPERSONAL_LOG_ARCHITECTURE(Format, ...) \
    UE_LOG(LogTranspersonalCore, Error, TEXT("[ARCHITECTURE] ") Format, ##__VA_ARGS__)

// ============================================================================
// VALIDATION MACROS (MANDATORY)
// ============================================================================

/**
 * ARCHITECTURAL VALIDATION:
 * Use these macros to validate architectural compliance
 */
#define TRANSPERSONAL_VALIDATE_SYSTEM(SystemName) \
    if (!IsValid(this)) \
    { \
        TRANSPERSONAL_LOG_ARCHITECTURE("Invalid system instance: %s", TEXT(#SystemName)); \
        return false; \
    }

#define TRANSPERSONAL_VALIDATE_PERFORMANCE(MaxTime) \
    { \
        float StartTime = FPlatformTime::Seconds(); \
        ON_SCOPE_EXIT \
        { \
            float ElapsedTime = (FPlatformTime::Seconds() - StartTime) * 1000.0f; \
            if (ElapsedTime > MaxTime) \
            { \
                TRANSPERSONAL_LOG_PERFORMANCE(Unknown, "Performance violation: %.2fms > %.2fms", ElapsedTime, MaxTime); \
            } \
        }; \
    }

#define TRANSPERSONAL_VALIDATE_MEMORY(MaxBytes) \
    { \
        SIZE_T StartMemory = FPlatformMemory::GetStats().UsedPhysical; \
        ON_SCOPE_EXIT \
        { \
            SIZE_T EndMemory = FPlatformMemory::GetStats().UsedPhysical; \
            SIZE_T AllocatedBytes = EndMemory - StartMemory; \
            if (AllocatedBytes > MaxBytes) \
            { \
                TRANSPERSONAL_LOG_PERFORMANCE(Unknown, "Memory violation: %llu bytes > %d bytes", AllocatedBytes, MaxBytes); \
            } \
        }; \
    }