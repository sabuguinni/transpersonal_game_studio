UENUM(BlueprintType)
enum class ECrowdLODLevel : uint8
{
    High,           // Full detail, full AI, full rendering
    Medium,         // Reduced AI frequency, simplified rendering
    Low,            // Basic AI, instanced rendering
    Off,            // No AI, culled from rendering
    Hibernating     // Completely disabled until needed
};

USTRUCT()
struct FCrowdLODFragment : public FMassFragment
{
    GENERATED_BODY()

    UPROPERTY(EditAnywhere, Category = "LOD")
    ECrowdLODLevel CurrentLODLevel = ECrowdLODLevel::Medium;

    UPROPERTY(EditAnywhere, Category = "LOD")
    ECrowdLODLevel PreviousLODLevel = ECrowdLODLevel::Medium;

    UPROPERTY(EditAnywhere, Category = "LOD")
    float DistanceToPlayer = 0.0f;

    UPROPERTY(EditAnywhere, Category = "LOD")
    float LastLODUpdateTime = 0.0f;

    UPROPERTY(EditAnywhere, Category = "LOD")
    float LODUpdateInterval = 1.0f;

    UPROPERTY(EditAnywhere, Category = "LOD")
    bool bIsVisible = true;

    UPROPERTY(EditAnywhere, Category = "LOD")
    bool bWasVisibleLastFrame = true;

    UPROPERTY(EditAnywhere, Category = "LOD")
    float VisibilityTimer = 0.0f;

    UPROPERTY(EditAnywhere, Category = "LOD")
    int32 FramesSinceVisible = 0;

    UPROPERTY(EditAnywhere, Category = "LOD")
    bool bForceHighLOD = false;

    UPROPERTY(EditAnywhere, Category = "LOD")
    float ImportanceScore = 1.0f;
};

