#pragma once\n\n#include "CoreMinimal.h"\n#include "Components/ActorComponent.h"\n#include "Engine/Engine.h"\n#include "DinosaurBehaviorSystem.generated.h"\n\n// Forward declarations\nclass AActor;\nclass UWorld;\n\n// Enums for dinosaur behavior\nUENUM(BlueprintType)\nenum class EDinosaurSpecies : uint8\n{\n    TRex           UMETA(DisplayName = "Tyrannosaurus Rex"),\n    Triceratops    UMETA(DisplayName = "Triceratops"),\n    Velociraptor   UMETA(DisplayName = "Velociraptor"),\n    Brontosaurus   UMETA(DisplayName = "Brontosaurus"),\n    Stegosaurus    UMETA(DisplayName = "Stegosaurus"),\n    Pteranodon     UMETA(DisplayName = "Pteranodon"),\n    Compsognathus  UMETA(DisplayName = "Compsognathus"),\n    Parasaurolophus UMETA(DisplayName = "Parasaurolophus")\n};\n\nUENUM(BlueprintType)\nenum class EDinosaurBehaviorState : uint8\n{\n    Idle           UMETA(DisplayName = "Idle"),\n    Foraging       UMETA(DisplayName = "Foraging"),\n    Hunting        UMETA(DisplayName = "Hunting"),\n    Drinking       UMETA(DisplayName = "Drinking"),\n    Resting        UMETA(DisplayName = "Resting"),\n    Socializing    UMETA(DisplayName = "Socializing"),\n    Territorial    UMETA(DisplayName = "Territorial"),\n    Fleeing        UMETA(DisplayName = "Fleeing"),\n    Investigating  UMETA(DisplayName = "Investigating"),\n    Mating         UMETA(DisplayName = "Mating")\n};\n\nUENUM(BlueprintType)\nenum class EDinosaurPersonality : uint8\n{\n    Timid          UMETA(DisplayName = "Timid"),\n    Curious        UMETA(DisplayName = "Curious"),\n    Aggressive     UMETA(DisplayName = "Aggressive"),\n    Calm           UMETA(DisplayName = "Calm"),\n    Playful        UMETA(DisplayName = "Playful"),\n    Territorial    UMETA(DisplayName = "Territorial"),\n    Social         UMETA(DisplayName = "Social")\n};\n\n// Structs for dinosaur data\nUSTRUCT(BlueprintType)\nstruct FDinosaurNeeds\n{\n    GENERATED_BODY()\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, meta = (ClampMin = "0.0", ClampMax = "100.0"))\n    float Hunger = 50.0f;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, meta = (ClampMin = "0.0", ClampMax = "100.0"))\n    float Thirst = 50.0f;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, meta = (ClampMin = "0.0", ClampMax = "100.0"))\n    float Energy = 80.0f;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, meta = (ClampMin = "0.0", ClampMax = "100.0"))\n    float Social = 50.0f;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, meta = (ClampMin = "0.0", ClampMax = "100.0"))\n    float Stress = 20.0f;\n};\n\nUSTRUCT(BlueprintType)\nstruct FDinosaurDailySchedule\n{\n    GENERATED_BODY()\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, meta = (ClampMin = "0.0", ClampMax = "24.0"))\n    float WakeUpTime = 6.0f;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, meta = (ClampMin = "0.0", ClampMax = "24.0"))\n    float SleepTime = 20.0f;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite)\n    TArray<float> FeedingTimes = {8.0f, 14.0f, 18.0f};\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite)\n    TArray<float> DrinkingTimes = {7.0f, 12.0f, 17.0f, 21.0f};\n};\n\nUSTRUCT(BlueprintType)\nstruct FDinosaurMemory\n{\n    GENERATED_BODY()\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite)\n    TMap<AActor*, float> KnownCreatures;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite)\n    TArray<FVector> KnownFoodSources;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite)\n    TArray<FVector> KnownWaterSources;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite)\n    TArray<FVector> KnownDangerAreas;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, meta = (ClampMin = "-100.0", ClampMax = "100.0"))\n    float PlayerTrustLevel = 0.0f;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite)\n    int32 PlayerInteractions = 0;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite)\n    float LastPlayerEncounterTime = 0.0f;\n};\n\n// Delegate declarations\nDECLARE_DYNAMIC_MULTICAST_DELEGATE_TwoParams(FOnBehaviorStateChanged, EDinosaurBehaviorState, OldState, EDinosaurBehaviorState, NewState);\nDECLARE_DYNAMIC_MULTICAST_DELEGATE_OneParam(FOnDomesticationLevelChanged, float, NewTrustLevel);\nDECLARE_DYNAMIC_MULTICAST_DELEGATE_TwoParams(FOnNeedsCritical, FString, NeedType, float, Value);\n\n/**\n * Comprehensive dinosaur behavior system that manages AI behavior, needs, memory, and player interaction\n * Each dinosaur has unique personality traits and daily routines\n */\nUCLASS(ClassGroup=(Custom), meta=(BlueprintSpawnableComponent))\nclass TRANSPERSONALGAME_API UDinosaurBehaviorSystem : public UActorComponent\n{\n    GENERATED_BODY()\n\npublic:\n    UDinosaurBehaviorSystem();\n\n    virtual void BeginPlay() override;\n    virtual void TickComponent(float DeltaTime, ELevelTick TickType, FActorComponentTickFunction* ThisTickFunction) override;\n\n    // Core Properties\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Dinosaur Identity")\n    EDinosaurSpecies Species = EDinosaurSpecies::Compsognathus;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Dinosaur Identity")\n    FString IndividualName;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Dinosaur Identity")\n    EDinosaurPersonality PrimaryPersonality = EDinosaurPersonality::Calm;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Dinosaur Identity")\n    EDinosaurPersonality SecondaryPersonality = EDinosaurPersonality::Curious;\n\n    // Current State\n    UPROPERTY(VisibleAnywhere, BlueprintReadOnly, Category = "Behavior")\n    EDinosaurBehaviorState CurrentState = EDinosaurBehaviorState::Idle;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Behavior")\n    FDinosaurNeeds Needs;\n\n    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Behavior")\n    FDinosaurDailySchedule DailySchedule;\n\n    UPROPERTY(VisibleAnywhere, BlueprintReadOnly, Category = "Memory")\n    FDinosaurMemory Memory;\n\n    // Delegates\n    UPROPERTY(BlueprintAssignable, Category = "Events")\n    FOnBehaviorStateChanged OnBehaviorStateChanged;\n\n    UPROPERTY(BlueprintAssignable, Category = "Events")\n    FOnDomesticationLevelChanged OnDomesticationLevelChanged;\n\n    UPROPERTY(BlueprintAssignable, Category = "Events")\n    FOnNeedsCritical OnNeedsCritical;\n\n    // Public Methods\n    UFUNCTION(BlueprintCallable, Category = "Dinosaur Behavior")\n    void ReactToPlayer(AActor* Player, float Distance, bool bPlayerVisible);\n\n    UFUNCTION(BlueprintCallable, Category = "Dinosaur Behavior")\n    void LearnFromExperience(AActor* Target, bool bPositiveExperience, float Intensity = 10.0f);\n\n    UFUNCTION(BlueprintCallable, Category = "Dinosaur Behavior")\n    void AddMemoryLocation(const FVector& Location, const FString& LocationType);\n\n    UFUNCTION(BlueprintCallable, Category = "Dinosaur Behavior")\n    bool CanBeDomesticated() const;\n\n    UFUNCTION(BlueprintCallable, Category = "Dinosaur Behavior")\n    float GetDomesticationLevel() const { return Memory.PlayerTrustLevel; }\n\n    UFUNCTION(BlueprintCallable, Category = "Dinosaur Behavior")\n    bool IsHerbivore() const;\n\n    UFUNCTION(BlueprintCallable, Category = "Dinosaur Behavior")\n    bool IsCarnivore() const;\n\n    UFUNCTION(BlueprintCallable, Category = "Dinosaur Behavior")\n    bool IsSocialSpecies() const;\n\n    UFUNCTION(BlueprintCallable, Category = "Dinosaur Behavior")\n    FVector GetNearestKnownLocation(const FString& LocationType) const;\n\nprotected:\n    // Internal state tracking\n    UPROPERTY()\n    float LastScheduleCheckTime = 0.0f;\n\n    UPROPERTY()\n    float LastNeedsUpdateTime = 0.0f;\n\n    // Core behavior methods\n    void UpdateNeeds(float DeltaTime);\n    void ProcessDailySchedule();\n    EDinosaurBehaviorState DetermineBehaviorState();\n    void DecayMemories(float DeltaTime);\n    \n    // Utility methods\n    void InitializeSpeciesDefaults();\n    float GetCurrentTimeOfDay() const;\n    bool IsTimeForActivity(float ScheduledTime, float ToleranceHours) const;\n    float CalculatePersonalityModifier(EDinosaurPersonality Personality, float BaseValue) const;\n    \n    // Memory management\n    void UpdateLocationMemory(const FVector& Location, const FString& Type);\n    void ForgetOldMemories();\n};

