    UFUNCTION(BlueprintCallable, Category = "Relationships")
    bool IsKnownActor(AActor* TargetActor);

    // Learning and Adaptation
    UFUNCTION(BlueprintCallable, Category = "Learning")
    void LearnFromExperience(FGameplayTag ExperienceType, bool bPositive, float Intensity = 1.0f);

    UFUNCTION(BlueprintCallable, Category = "Learning")
