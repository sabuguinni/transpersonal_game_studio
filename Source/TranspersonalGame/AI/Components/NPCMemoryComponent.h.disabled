// [UHT-FIX]     UFUNCTION(BlueprintCallable, Category = "Memory")
    TArray<FMemoryEntry> GetMemoriesByTag(FGameplayTag EventTag);

// [UHT-FIX]     UFUNCTION(BlueprintCallable, Category = "Memory")
    TArray<FMemoryEntry> GetMemoriesWithActor(AActor* Actor);

    UFUNCTION(BlueprintCallable, Category = "Memory")
    void ForgetOldMemories(float MaxAge = 86400.0f); // 24 hours default

    // Relationship Management
    UFUNCTION(BlueprintCallable, Category = "Relationships")
    void UpdateRelationship(AActor* TargetActor, float TrustChange, float FamiliarityChange);

// [UHT-FIX]     UFUNCTION(BlueprintCallable, Category = "Relationships")
