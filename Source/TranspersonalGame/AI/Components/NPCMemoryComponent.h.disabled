    UFUNCTION(BlueprintCallable, Category = "Learning")
    bool ShouldAvoidActor(AActor* Actor);

    // Memory Queries
    UFUNCTION(BlueprintCallable, Category = "Memory")
    FVector GetLastKnownLocationOf(AActor* Actor);

    UFUNCTION(BlueprintCallable, Category = "Memory")
    float GetTimeSinceLastSeen(AActor* Actor);

    UFUNCTION(BlueprintCallable, Category = "Memory")
    TArray<FVector> GetDangerousLocations();

    UFUNCTION(BlueprintCallable, Category = "Memory")
    TArray<FVector> GetSafeLocations();

    UFUNCTION(BlueprintCallable, Category = "Memory")
    TArray<FVector> GetFoodLocations();

    UFUNCTION(BlueprintCallable, Category = "Memory")
    TArray<FVector> GetWaterLocations();

protected:
