USTRUCT(BlueprintType)
struct TRANSPERSONALGAME_API FSurvivalChallenge
{
    GENERATED_BODY()

    UPROPERTY(EditAnywhere, BlueprintReadWrite)
    FGameplayTag ChallengeType; // Hunger, Thirst, Temperature, Predator

