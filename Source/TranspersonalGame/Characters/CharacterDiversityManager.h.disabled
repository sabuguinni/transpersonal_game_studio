#include "CoreMinimal.h"
#include "Subsystems/WorldSubsystem.h"
#include "Engine/DataTable.h"
#include "JurassicCharacterArtist.h"
#include "TranspersonalGameSharedTypes.h"
#include "CharacterDiversityManager.generated.h"

class ACharacter;


