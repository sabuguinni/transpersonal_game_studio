/**
 * Performance Metrics Collection
 * Utility class for collecting and analyzing performance data
 */
struct FQAPerformanceMetrics
{
    float AverageFPS;
    float MinFPS;
    float MaxFPS;
    float FrameTimeVariance;
    
    int32 MemoryUsageMB;
    int32 GPUMemoryUsageMB;
    
    int32 DrawCalls;
    int32 Triangles;
    
    float PhysicsStepTime;
    float AITickTime;
    
    bool bMetricsValid;
    
    FQAPerformanceMetrics()
        : AverageFPS(0.0f)
        , MinFPS(0.0f)
        , MaxFPS(0.0f)
        , FrameTimeVariance(0.0f)
        , MemoryUsageMB(0)
        , GPUMemoryUsageMB(0)
        , DrawCalls(0)
        , Triangles(0)
        , PhysicsStepTime(0.0f)
        , AITickTime(0.0f)
        , bMetricsValid(false)
    {}
};

/**
 * Performance Metrics Collector
 * Collects real-time performance metrics during testing
 */
class TRANSPERSONALGAME_API FQAPerformanceCollector
{
public:
    static FQAPerformanceMetrics CollectMetrics(float SampleDuration = 5.0f);
    static bool ValidateMetricsAgainstThresholds(const FQAPerformanceMetrics& Metrics);
    static FString FormatMetricsReport(const FQAPerformanceMetrics& Metrics);
    
private:
    static void CollectFrameRateMetrics(FQAPerformanceMetrics& Metrics, float SampleDuration);
    static void CollectMemoryMetrics(FQAPerformanceMetrics& Metrics);
    static void CollectRenderingMetrics(FQAPerformanceMetrics& Metrics);
    static void CollectPhysicsMetrics(FQAPerformanceMetrics& Metrics);
    static void CollectAIMetrics(FQAPerformanceMetrics& Metrics);
};