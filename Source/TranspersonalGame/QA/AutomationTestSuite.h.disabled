/**
 * Main QA Test Suite Class
 * Coordinates and manages all automated tests
 */
UCLASS(BlueprintType, Blueprintable)
class TRANSPERSONALGAME_API UTranspersonalQATestSuite : public UObject
{
    GENERATED_BODY()

public:
    /**
     * Get the current test world for automation testing
     * @return Valid UWorld pointer or nullptr if no world available
     */
    UFUNCTION(BlueprintCallable, Category = "QA Testing")
    static UWorld* GetTestWorld();

    /**
     * Run all automated tests in the suite
     * This function queues all tests for execution by the automation framework
     */
    UFUNCTION(BlueprintCallable, Category = "QA Testing")
    static void RunAllTests();

    /**
     * Test Categories for organization
     */

    /**
     * Test Priority Levels
     */

    /**
     * Test Result Status
     */

protected:
    /**
     * Test configuration and settings
     */
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "QA Configuration")
    bool bEnablePerformanceTesting = true;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "QA Configuration")
    bool bEnableStressTesting = false;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "QA Configuration")
    float PerformanceTestDuration = 30.0f;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "QA Configuration")
    int32 MaxConcurrentTests = 4;

    /**
     * Performance thresholds
     */
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Performance Thresholds")
    float MinimumFPS = 30.0f;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Performance Thresholds")
    float MaxMemoryUsageMB = 8192.0f;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Performance Thresholds")
    float MaxLoadTimeSec = 60.0f;
};

/**
 * QA Test Macros for simplified test creation
 */
#define TRANSPERSONAL_QA_TEST(TestName, Category, Priority) \
    IMPLEMENT_SIMPLE_AUTOMATION_TEST(F##TestName##Test, "TranspersonalGame." #Category "." #TestName, \
        EAutomationTestFlags::EditorContext | EAutomationTestFlags::ProductFilter | EAutomationTestFlags::EditorContext | EAutomationTestFlags::ProductFilter)

#define TRANSPERSONAL_QA_COMPLEX_TEST(TestName, Category, Priority) \
    IMPLEMENT_COMPLEX_AUTOMATION_TEST(F##TestName##Test, "TranspersonalGame." #Category "." #TestName, \
        EAutomationTestFlags::EditorContext | EAutomationTestFlags::ProductFilter | EAutomationTestFlags::EditorContext | EAutomationTestFlags::ProductFilter)

/**
 * QA Logging Macros
 */
#define QA_LOG(Format, ...) UE_LOG(LogTranspersonalQA, Log, Format, ##__VA_ARGS__)
#define QA_WARNING(Format, ...) UE_LOG(LogTranspersonalQA, Warning, Format, ##__VA_ARGS__)
#define QA_ERROR(Format, ...) UE_LOG(LogTranspersonalQA, Error, Format, ##__VA_ARGS__)

/**
 * QA Test Assertion Macros
 */
#define QA_ASSERT_TRUE(Condition, Message) \
    if (!(Condition)) { \
        AddError(FString::Printf(TEXT("Assertion failed: %s"), Message)); \
        return false; \
    }

#define QA_ASSERT_FALSE(Condition, Message) \
    if (Condition) { \
        AddError(FString::Printf(TEXT("Assertion failed: %s"), Message)); \
        return false; \
    }

#define QA_ASSERT_NOT_NULL(Pointer, Message) \
    if (!Pointer) { \
        AddError(FString::Printf(TEXT("Null pointer: %s"), Message)); \
        return false; \
    }