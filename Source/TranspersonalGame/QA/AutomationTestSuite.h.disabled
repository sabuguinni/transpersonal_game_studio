#pragma once

#include "CoreMinimal.h"
#include "UObject/NoExportTypes.h"
#include "Engine/World.h"
#include "Misc/AutomationTest.h"
#include "AutomationTestSuite.generated.h"

DECLARE_LOG_CATEGORY_EXTERN(LogTranspersonalQA, Log, All);

/**
 * Comprehensive QA Test Suite for Transpersonal Game
 * Implements automated testing for all major game systems
 * 
 * Test Categories:
 * - Core System Tests: Engine initialization, world context, game instance
 * - VFX System Tests: Niagara integration, particle systems, material systems
 * - AI System Tests: Behavior trees, blackboards, AI controllers
 * - Navigation Tests: NavMesh generation, pathfinding, navigation queries
 * - Performance Tests: Frame rate monitoring, memory usage, garbage collection
 * - Audio System Tests: Sound integration, audio components, MetaSounds
 * 
 * Usage:
 * - Run via Automation Test Framework in UE5 Editor
 * - Execute through Session Frontend for distributed testing
 * - Integrate with CI/CD pipeline for automated validation
 */

/**
 * Core System Automation Test
 * Tests fundamental engine and game systems initialization
 */
UENUM(BlueprintType)
enum class EQATestCategory : uint8
{
CoreSystems     UMETA(DisplayName = "Core Systems"),
VFXSystems      UMETA(DisplayName = "VFX Systems"),
AISystems       UMETA(DisplayName = "AI Systems"),
Navigation      UMETA(DisplayName = "Navigation"),
Performance     UMETA(DisplayName = "Performance"),
AudioSystems    UMETA(DisplayName = "Audio Systems"),
Integration     UMETA(DisplayName = "Integration"),
Regression      UMETA(DisplayName = "Regression")
};

UENUM(BlueprintType)
enum class EQATestPriority : uint8
{
Critical        UMETA(DisplayName = "Critical"),
High            UMETA(DisplayName = "High"),
Medium          UMETA(DisplayName = "Medium"),
Low             UMETA(DisplayName = "Low"),
Smoke           UMETA(DisplayName = "Smoke Test")
};

UENUM(BlueprintType)
enum class EQA_QATestResult : uint8
{
NotRun          UMETA(DisplayName = "Not Run"),
Running         UMETA(DisplayName = "Running"),
Passed          UMETA(DisplayName = "Passed"),
Failed          UMETA(DisplayName = "Failed"),
Skipped         UMETA(DisplayName = "Skipped"),
Warning         UMETA(DisplayName = "Warning")
};


class TRANSPERSONALGAME_API FTranspersonalCoreSystemTest : public FAutomationTestBase
{
public:
    FTranspersonalCoreSystemTest(const FString& InName, const bool bInComplexTask)
        : FAutomationTestBase(InName, bInComplexTask) {}

    /* DISABLED: virtual bool RunTest(const FString& Parameters) override */;
    virtual EAutomationTestFlags GetTestFlags() const override { return EAutomationTestFlags::EditorContext | EAutomationTestFlags::ProductFilter | EAutomationTestFlags::EditorContext | EAutomationTestFlags::ProductFilter; }
    virtual FString GetBeautifiedTestName() const override { return TEXT("Core System Initialization"); }
};

