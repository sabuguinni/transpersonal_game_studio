/**
 * Story Bible - The complete narrative framework for the transpersonal prehistoric experience
 * Contains all story beats, character voices, themes, and lore for the game
 */
UCLASS(BlueprintType, Blueprintable)
class TRANSPERSONALGAME_API UStoryBible : public UPrimaryDataAsset
{
    GENERATED_BODY()

public:
    UStoryBible();

    // Core story structure
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Structure")
    FText GameTitle;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Structure")
    FText GameSubtitle;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Structure")
    FText CorePremise;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Structure")
    FText CentralTheme;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Structure")
    TArray<FStoryTheme> MajorThemes;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Structure")
    TArray<FNarr_StoryBeat_C47> StoryBeats;

    // Character voices and archetypes
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Characters")
    TArray<FCharacterVoice> CharacterVoices;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Characters")
    FText ProtagonistBackground;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Characters")
    FText ProtagonistMotivation;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Characters")
    FText ProtagonistArc;

    // World and lore
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|World")
    TArray<FWorldLore> WorldLore;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|World")
    FText WorldDescription;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|World")
    FText TimePeridSetting;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|World")
    FText GeographicalSetting;

    // Transpersonal elements
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Transpersonal")
    FText TranspersonalPhilosophy;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Transpersonal")
    TArray<FString> SacredSites;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Transpersonal")
    TArray<FString> RitualExperiences;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Transpersonal")
    TArray<FString> ConsciousnessStates;

    // Emotional journey
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Emotion")
    TMap<ENarr_StoryAct, ENarrativeTone> ActEmotionalTones;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Emotion")
    TArray<FString> EmotionalMilestones;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Emotion")
    FText EmotionalArc;

    // Dialogue guidelines
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Dialogue")
    FText DialogueStyle;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Dialogue")
    FText VoiceActingDirection;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Dialogue")
    TMap<ENarrativeTone, FText> ToneGuidelines;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Dialogue")
    TMap<EDialogueContext, FText> ContextGuidelines;

    // Quest integration
    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Quests")
    TArray<FString> MainStoryQuests;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Quests")
    TArray<FString> CharacterDevelopmentQuests;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Story|Quests")
    TArray<FString> WorldBuildingQuests;

    // Utility functions
    UFUNCTION(BlueprintCallable, Category = "Story Bible")
    FNarr_StoryBeat_C47 GetStoryBeatByID(const FString& BeatID) const;

    UFUNCTION(BlueprintCallable, Category = "Story Bible")
    TArray<FNarr_StoryBeat_C47> GetStoryBeatsForAct(ENarr_StoryAct Act) const;

    UFUNCTION(BlueprintCallable, Category = "Story Bible")
    FCharacterVoice GetCharacterVoiceByID(const FString& VoiceID) const;

    UFUNCTION(BlueprintCallable, Category = "Story Bible")
    TArray<FCharacterVoice> GetCharacterVoicesByArchetype(ENarr_CharacterArchetype_C47 Archetype) const;

    UFUNCTION(BlueprintCallable, Category = "Story Bible")
    FWorldLore GetWorldLoreByID(const FString& LoreID) const;

    UFUNCTION(BlueprintCallable, Category = "Story Bible")
    TArray<FWorldLore> GetDiscoveredLore() const;

    UFUNCTION(BlueprintCallable, Category = "Story Bible")
    FStoryTheme GetThemeByID(const FString& ThemeID) const;

    UFUNCTION(BlueprintCallable, Category = "Story Bible")
    TArray<FString> GetActiveThemes(const TArray<FGameplayTag>& CurrentTags) const;

    UFUNCTION(BlueprintCallable, Category = "Story Bible")
    ENarrativeTone GetRecommendedToneForContext(EDialogueContext Context, const TArray<FGameplayTag>& Tags) const;

    UFUNCTION(BlueprintCallable, Category = "Story Bible")
    TArray<FString> GetContextualDialogueKeys(EDialogueContext Context, ENarrativeTone Tone) const;

protected:
    // Internal data validation
    virtual void PostLoad() override;
    
#if WITH_EDITOR
    virtual void PostEditChangeProperty(FPropertyChangedEvent& PropertyChangedEvent) override;
#endif

private:
    void ValidateStoryStructure();
    void ValidateCharacterVoices();
    void ValidateWorldLore();
    void InitializeDefaultContent();
};
#endif // HEADER_DISABLED
