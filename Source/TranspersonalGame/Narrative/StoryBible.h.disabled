UENUM(BlueprintType)
enum class ENarr_StoryAct : uint8
{
    Prologue,           // The discovery and time travel
    Act1_Arrival,       // First moments in prehistoric world
    Act2_Survival,      // Learning to survive and adapt
    Act3_Discovery,     // Understanding the world and creatures
    Act4_Connection,    // Forming bonds with environment
    Act5_Revelation,    // Understanding the deeper mystery
    Act6_Transformation,// Personal growth and acceptance
    Epilogue_Return     // Finding the gem and returning home
};

UENUM(BlueprintType)
enum class ENarr_CharacterArchetype_C47 : uint8
{
    Protagonist,        // The time-displaced paleontologist
    Narrator,           // Internal voice/consciousness
    EnvironmentVoice,   // The world itself speaking
    CreatureSpirit,     // Essence of dinosaur consciousness
    AncientWisdom,      // Transpersonal guidance
    ModernMemory,       // Memories from the present
    FearVoice,          // Survival instincts
    WonderVoice,        // Sense of awe and discovery
    ScientificMind,     // Analytical thoughts
    PrimalSelf          // Instinctual responses
};

USTRUCT(BlueprintType)
struct FStoryTheme
{
    GENERATED_BODY()

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Theme")
    FString ThemeID;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Theme")
    FText ThemeName;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Theme")
    FText ThemeDescription;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Theme")
    TArray<FGameplayTag> RelatedTags;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Theme")
    TArray<FString> KeyMoments;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Theme")
    float ThemeWeight = 1.0f;

    FStoryTheme()
    {
        ThemeID = TEXT("");
        ThemeName = FText::GetEmpty();
        ThemeDescription = FText::GetEmpty();
        ThemeWeight = 1.0f;
    }
};

USTRUCT(BlueprintType)
struct FNarr_StoryBeat_C47
{
    GENERATED_BODY()

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    FString BeatID;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    FText BeatTitle;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    FText BeatDescription;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    ENarr_StoryAct Act = ENarr_StoryAct::Act1_Arrival;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    ENarrativeEventType EventType = ENarrativeEventType::Discovery;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    ENarrativeTone EmotionalTone = ENarrativeTone::Neutral;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    TArray<FString> TriggerConditions;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    TArray<FString> RequiredQuests;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    TArray<FGameplayTag> RequiredTags;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    FVector PreferredLocation = FVector::ZeroVector;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    float LocationRadius = 1000.0f;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    bool bIsOptional = false;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    bool bIsRepeatable = false;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    int32 Priority = 1;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    TArray<FString> DialogueSequences;

    UPROPERTY(EditAnywhere, BlueprintReadWrite, Category = "Beat")
    TArray<FString> UnlockedContent;

    FNarr_StoryBeat_C47()
    {
        BeatID = TEXT("");
        BeatTitle = FText::GetEmpty();
        BeatDescription = FText::GetEmpty();
        Act = ENarr_StoryAct::Act1_Arrival;
        EventType = ENarrativeEventType::Discovery;
        EmotionalTone = ENarrativeTone::Neutral;
        PreferredLocation = FVector::ZeroVector;
        LocationRadius = 1000.0f;
        bIsOptional = false;
        bIsRepeatable = false;
        Priority = 1;
    }
};

