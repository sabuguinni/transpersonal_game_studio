// Post Process Material for Consciousness State Visualization
// Creates visual filters that respond to player's consciousness level

Begin Object Class=/Script/Engine.Material Name="PP_ConsciousnessFilter"
   MaterialDomain=MD_PostProcess
   BlendableLocation=BL_BeforeTonemapping
   
   // Parameters for consciousness visualization
   ScalarParameterValues=(ParameterName="ConsciousnessLevel",ParameterValue=0.5)
   ScalarParameterValues=(ParameterName="FilterIntensity",ParameterValue=0.3)
   ScalarParameterValues=(ParameterName="ChromaticAberration",ParameterValue=0.1)
   ScalarParameterValues=(ParameterName="Bloom",ParameterValue=1.2)
   ScalarParameterValues=(ParameterName="Saturation",ParameterValue=1.0)
   
   // Color grading based on consciousness state
   VectorParameterValues=(ParameterName="HighStateColor",ParameterValue=(R=1.1,G=1.05,B=0.9,A=1.0))
   VectorParameterValues=(ParameterName="LowStateColor",ParameterValue=(R=0.9,G=0.95,B=1.1,A=1.0))
   VectorParameterValues=(ParameterName="NeutralColor",ParameterValue=(R=1.0,G=1.0,B=1.0,A=1.0))
   
   // Effects:
   // - Warm tint for higher consciousness
   // - Cool tint for lower consciousness
   // - Bloom intensity varies with awareness
   // - Subtle chromatic aberration for altered states
   
End Object