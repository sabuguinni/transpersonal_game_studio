// Dynamic Glow Material for Consciousness States
// Material Blueprint with parameters for consciousness-responsive lighting

Begin Object Class=/Script/Engine.Material Name="M_ConsciousnessGlow"
   MaterialDomain=MD_Surface
   BlendMode=BLEND_Additive
   ShadingModel=MSM_Unlit
   
   // Base Parameters
   ScalarParameterValues=(ParameterName="Intensity",ParameterValue=1.0)
   ScalarParameterValues=(ParameterName="ConsciousnessLevel",ParameterValue=0.5)
   ScalarParameterValues=(ParameterName="PulseSpeed",ParameterValue=2.0)
   ScalarParameterValues=(ParameterName="ColorShift",ParameterValue=0.0)
   
   // Vector Parameters for Colors
   VectorParameterValues=(ParameterName="BaseColor",ParameterValue=(R=0.2,G=0.6,B=1.0,A=1.0))
   VectorParameterValues=(ParameterName="HighConsciousnessColor",ParameterValue=(R=1.0,G=0.8,B=0.2,A=1.0))
   VectorParameterValues=(ParameterName="LowConsciousnessColor",ParameterValue=(R=0.8,G=0.2,B=0.2,A=1.0))
   
   // Material Expression Network
   // Lerp between colors based on consciousness level
   // Time-based pulsing effect
   // Fresnel for edge glow
   
End Object