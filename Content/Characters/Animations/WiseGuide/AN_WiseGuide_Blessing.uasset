# Wise Guide Blessing Animation
# Ceremonial blessing gesture with energy emanation

import unreal

class WiseGuideBlessing:
    def __init__(self):
        self.duration = 5.0
        self.loop = False
        self.energy_particle_system = True
        
    def create_keyframes(self):
        # Frame 0: Initial stance, hands at sides
        keyframe_0 = {
            'time': 0.0,
            'spine_01': {'rotation': (0, 0, 0)},
            'spine_02': {'rotation': (2, 0, 0)},
            'spine_03': {'rotation': (3, 0, 0)},
            'head': {'rotation': (5, 0, 0)},
            'upperarm_l': {'rotation': (0, 0, 0)},
            'upperarm_r': {'rotation': (0, 0, 0)},
            'lowerarm_l': {'rotation': (0, 0, 0)},
            'lowerarm_r': {'rotation': (0, 0, 0)},
            'hand_l': {'rotation': (0, 0, 0)},
            'hand_r': {'rotation': (0, 0, 0)}
        }
        
        # Frame 60: Arms beginning to rise
        keyframe_60 = {
            'time': 2.0,
            'spine_01': {'rotation': (0, 0, 0)},
            'spine_02': {'rotation': (5, 0, 0)},
            'spine_03': {'rotation': (8, 0, 0)},
            'head': {'rotation': (10, 0, 0)},
            'upperarm_l': {'rotation': (-45, 0, -30)},
            'upperarm_r': {'rotation': (-45, 0, 30)},
            'lowerarm_l': {'rotation': (0, 0, -60)},
            'lowerarm_r': {'rotation': (0, 0, 60)},
            'hand_l': {'rotation': (-30, 0, 0)},
            'hand_r': {'rotation': (-30, 0, 0)}
        }
        
        # Frame 120: Peak blessing pose
        keyframe_120 = {
            'time': 4.0,
            'spine_01': {'rotation': (0, 0, 0)},
            'spine_02': {'rotation': (8, 0, 0)},
            'spine_03': {'rotation': (12, 0, 0)},
            'head': {'rotation': (15, 0, 0)},
            'upperarm_l': {'rotation': (-90, 0, -45)},
            'upperarm_r': {'rotation': (-90, 0, 45)},
            'lowerarm_l': {'rotation': (0, 0, -90)},
            'lowerarm_r': {'rotation': (0, 0, 90)},
            'hand_l': {'rotation': (-45, 0, 0)},
            'hand_r': {'rotation': (-45, 0, 0)}
        }
        
        # Frame 150: Return to rest
        keyframe_150 = keyframe_0.copy()
        keyframe_150['time'] = 5.0
        
        return [keyframe_0, keyframe_60, keyframe_120, keyframe_150]
        
    def create_energy_effects(self):
        # Golden light particles emanating from hands
        return {
            'blessing_particles': {
                'spawn_rate': 30,
                'lifetime': 3.0,
                'velocity': (0, 0, 50),
                'color': (1.0, 0.8, 0.3, 0.7),
                'size': (3, 8),
                'emission_points': ['hand_l', 'hand_r']
            },
            'aura_glow': {
                'intensity': 1.5,
                'color': (1.0, 0.9, 0.6),
                'radius': 200
            }
        }