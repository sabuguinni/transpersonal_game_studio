# Shadow Self Emergence Animation
# Animation for the shadow self materializing from darkness

import unreal

class ShadowSelfEmergence:
    def __init__(self):
        self.duration = 3.0
        self.loop = False
        self.material_opacity_curve = True
        
    def create_keyframes(self):
        # Frame 0: Hidden in shadow, crouched low
        keyframe_0 = {
            'time': 0.0,
            'root': {'translation': (0, 0, -50)},
            'spine_01': {'rotation': (45, 0, 0)},
            'spine_02': {'rotation': (30, 0, 0)},
            'spine_03': {'rotation': (20, 0, 0)},
            'head': {'rotation': (-30, 0, 0)},
            'thigh_l': {'rotation': (90, 0, 0)},
            'thigh_r': {'rotation': (90, 0, 0)},
            'calf_l': {'rotation': (-120, 0, 0)},
            'calf_r': {'rotation': (-120, 0, 0)},
            'upperarm_l': {'rotation': (45, 0, -30)},
            'upperarm_r': {'rotation': (45, 0, 30)},
            'lowerarm_l': {'rotation': (0, 0, -90)},
            'lowerarm_r': {'rotation': (0, 0, 90)},
            'material_opacity': 0.0
        }
        
        # Frame 45: Beginning to rise, becoming visible
        keyframe_45 = {
            'time': 1.5,
            'root': {'translation': (0, 0, -25)},
            'spine_01': {'rotation': (25, 0, 0)},
            'spine_02': {'rotation': (15, 0, 0)},
            'spine_03': {'rotation': (10, 0, 0)},
            'head': {'rotation': (-10, 0, 0)},
            'thigh_l': {'rotation': (45, 0, 0)},
            'thigh_r': {'rotation': (45, 0, 0)},
            'calf_l': {'rotation': (-60, 0, 0)},
            'calf_r': {'rotation': (-60, 0, 0)},
            'upperarm_l': {'rotation': (20, 0, -20)},
            'upperarm_r': {'rotation': (20, 0, 20)},
            'lowerarm_l': {'rotation': (0, 0, -45)},
            'lowerarm_r': {'rotation': (0, 0, 45)},
            'material_opacity': 0.5
        }
        
        # Frame 90: Fully emerged, menacing stance
        keyframe_90 = {
            'time': 3.0,
            'root': {'translation': (0, 0, 0)},
            'spine_01': {'rotation': (0, 0, 0)},
            'spine_02': {'rotation': (-5, 0, 0)},
            'spine_03': {'rotation': (-5, 0, 0)},
            'head': {'rotation': (10, 0, 0)},
            'thigh_l': {'rotation': (0, 0, 0)},
            'thigh_r': {'rotation': (0, 0, 0)},
            'calf_l': {'rotation': (0, 0, 0)},
            'calf_r': {'rotation': (0, 0, 0)},
            'upperarm_l': {'rotation': (-10, 0, -15)},
            'upperarm_r': {'rotation': (-10, 0, 15)},
            'lowerarm_l': {'rotation': (0, 0, -30)},
            'lowerarm_r': {'rotation': (0, 0, 30)},
            'hand_l': {'rotation': (0, 0, -45)},
            'hand_r': {'rotation': (0, 0, 45)},
            'material_opacity': 1.0
        }
        
        return [keyframe_0, keyframe_45, keyframe_90]
        
    def create_particle_effects(self):
        # Dark smoke particles during emergence
        return {
            'smoke_particles': {
                'spawn_rate': 50,
                'lifetime': 2.0,
                'velocity': (0, 0, 25),
                'color': (0.1, 0.1, 0.1, 0.8),
                'size': (5, 15)
            }
        }