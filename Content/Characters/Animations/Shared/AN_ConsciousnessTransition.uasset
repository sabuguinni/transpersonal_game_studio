# Consciousness Transition Animation
# Universal animation for state changes between consciousness levels

import unreal

class ConsciousnessTransition:
    def __init__(self):
        self.duration = 4.0
        self.loop = False
        self.morphing_effect = True
        
    def create_keyframes(self):
        # Frame 0: Current state (neutral)
        keyframe_0 = {
            'time': 0.0,
            'root': {'translation': (0, 0, 0)},
            'spine_01': {'rotation': (0, 0, 0)},
            'spine_02': {'rotation': (0, 0, 0)},
            'spine_03': {'rotation': (0, 0, 0)},
            'head': {'rotation': (0, 0, 0)},
            'material_distortion': 0.0,
            'energy_field_intensity': 0.0
        }
        
        # Frame 60: Dissolution phase
        keyframe_60 = {
            'time': 2.0,
            'root': {'translation': (0, 0, 10)},
            'spine_01': {'rotation': (0, 0, 0)},
            'spine_02': {'rotation': (10, 0, 0)},
            'spine_03': {'rotation': (15, 0, 0)},
            'head': {'rotation': (20, 0, 0)},
            'upperarm_l': {'rotation': (-60, 0, -30)},
            'upperarm_r': {'rotation': (-60, 0, 30)},
            'lowerarm_l': {'rotation': (0, 0, -60)},
            'lowerarm_r': {'rotation': (0, 0, 60)},
            'material_distortion': 1.0,
            'energy_field_intensity': 1.5
        }
        
        # Frame 120: New state emergence
        keyframe_120 = {
            'time': 4.0,
            'root': {'translation': (0, 0, 0)},
            'spine_01': {'rotation': (0, 0, 0)},
            'spine_02': {'rotation': (0, 0, 0)},
            'spine_03': {'rotation': (0, 0, 0)},
            'head': {'rotation': (0, 0, 0)},
            'upperarm_l': {'rotation': (0, 0, 0)},
            'upperarm_r': {'rotation': (0, 0, 0)},
            'lowerarm_l': {'rotation': (0, 0, 0)},
            'lowerarm_r': {'rotation': (0, 0, 0)},
            'material_distortion': 0.0,
            'energy_field_intensity': 0.3
        }
        
        return [keyframe_0, keyframe_60, keyframe_120]
        
    def create_transition_effects(self):
        # Energy field and particle effects for consciousness shifts
        return {
            'consciousness_field': {
                'spawn_rate': 100,
                'lifetime': 2.0,
                'velocity_spiral': True,
                'color_gradient': [(0.3, 0.1, 0.8, 0.8), (0.9, 0.3, 1.0, 0.6)],
                'size': (2, 12),
                'emission_shape': 'sphere'
            },
            'reality_distortion': {
                'shader_effect': 'wave_distortion',
                'intensity_curve': [0.0, 1.0, 0.0],
                'frequency': 3.0
            }
        }