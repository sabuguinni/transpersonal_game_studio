# Master Animation Blueprint for Transpersonal Game Characters
# Handles state machines and consciousness-based animation blending

import unreal

class TranspersonalCharacterAnimBP:
    def __init__(self):
        self.consciousness_level = 0.0  # 0-1 range
        self.emotional_state = "neutral"
        self.is_in_transition = False
        self.current_archetype = "protagonist"
        
    def create_state_machine(self):
        # Main state machine for character animations
        states = {
            'idle': {
                'protagonist': 'AN_Protagonist_Idle_Meditation',
                'shadow_self': 'AN_ShadowSelf_Lurking',
                'wise_guide': 'AN_WiseGuide_Contemplation',
                'inner_child': 'AN_InnerChild_Curious'
            },
            'movement': {
                'protagonist': 'AN_Protagonist_Walk_Mindful',
                'shadow_self': 'AN_ShadowSelf_Stalking',
                'wise_guide': 'AN_WiseGuide_Floating',
                'inner_child': 'AN_InnerChild_Skipping'
            },
            'interaction': {
                'protagonist': 'AN_Protagonist_Reaching',
                'shadow_self': 'AN_ShadowSelf_Grasping',
                'wise_guide': 'AN_WiseGuide_Blessing',
                'inner_child': 'AN_InnerChild_PlayfulDance'
            },
            'transformation': {
                'all': 'AN_ConsciousnessTransition'
            }
        }
        return states
        
    def create_blend_spaces(self):
        # 2D blend space for consciousness level vs emotional intensity
        blend_space = {
            'name': 'BS_ConsciousnessEmotion',
            'x_axis': 'consciousness_level',  # 0 = ego, 1 = transcendent
            'y_axis': 'emotional_intensity',  # 0 = calm, 1 = intense
            'samples': [
                {'position': (0.0, 0.0), 'animation': 'AN_Protagonist_Idle_Meditation'},
                {'position': (0.0, 1.0), 'animation': 'AN_ShadowSelf_Emergence'},
                {'position': (1.0, 0.0), 'animation': 'AN_WiseGuide_Blessing'},
                {'position': (1.0, 1.0), 'animation': 'AN_InnerChild_PlayfulDance'},
                {'position': (0.5, 0.5), 'animation': 'AN_ConsciousnessTransition'}
            ]
        }
        return blend_space
        
    def create_animation_curves(self):
        # Curves for smooth transitions between consciousness states
        curves = {
            'consciousness_breathing': {
                'duration': 4.0,
                'loop': True,
                'keyframes': [
                    {'time': 0.0, 'value': 0.0},
                    {'time': 2.0, 'value': 1.0},
                    {'time': 4.0, 'value': 0.0}
                ]
            },
            'energy_flow': {
                'duration': 6.0,
                'loop': True,
                'keyframes': [
                    {'time': 0.0, 'value': 0.3},
                    {'time': 1.5, 'value': 0.8},
                    {'time': 3.0, 'value': 1.0},
                    {'time': 4.5, 'value': 0.6},
                    {'time': 6.0, 'value': 0.3}
                ]
            }
        }
        return curves
        
    def create_notify_events(self):
        # Animation notify events for consciousness effects
        notifies = {
            'consciousness_shift_start': {
                'trigger_particles': True,
                'particle_system': 'PS_ConsciousnessField',
                'sound_effect': 'SFX_EnergyShift'
            },
            'archetype_emergence': {
                'trigger_particles': True,
                'particle_system': 'PS_ArchetypeAura',
                'material_effect': 'MAT_ConsciousnessGlow'
            },
            'energy_pulse': {
                'trigger_particles': True,
                'particle_system': 'PS_EnergyWave',
                'camera_shake': 'CS_ConsciousnessShift'
            }
        }
        return notifies