// Animation Blueprint para o personagem principal (paleontologista)
// Este arquivo representa a estrutura do Animation Blueprint no formato de asset

{
    "AssetType": "AnimationBlueprint",
    "TargetSkeleton": "/Game/Characters/Player/SK_PlayerCharacter",
    "ParentClass": "AnimInstance",
    
    "AnimGraph": {
        "Nodes": [
            {
                "Type": "MotionMatchingNode",
                "Name": "MotionMatching_Locomotion",
                "Database": "/Game/Characters/Player/Animation/MotionMatching/DB_PlayerLocomotion",
                "Schema": "/Game/Characters/Player/Animation/MotionMatching/Schema_PlayerLocomotion",
                "BlendTime": 0.2,
                "Position": {"X": 200, "Y": 100}
            },
            {
                "Type": "TerrainIKNode", 
                "Name": "TerrainIK",
                "LeftFootIKBone": "ik_foot_l",
                "RightFootIKBone": "ik_foot_r",
                "HipBone": "pelvis",
                "Position": {"X": 400, "Y": 100}
            },
            {
                "Type": "OrientationWarpingNode",
                "Name": "OrientationWarping",
                "WarpingMode": "GroundSlope",
                "Position": {"X": 600, "Y": 100}
            },
            {
                "Type": "OutputPoseNode",
                "Name": "OutputPose",
                "Position": {"X": 800, "Y": 100}
            }
        ],
        "Connections": [
            {"From": "MotionMatching_Locomotion.Pose", "To": "TerrainIK.InputPose"},
            {"From": "TerrainIK.OutputPose", "To": "OrientationWarping.InputPose"},
            {"From": "OrientationWarping.OutputPose", "To": "OutputPose.Result"}
        ]
    },
    
    "EventGraph": {
        "Variables": [
            {
                "Name": "MovementSpeed",
                "Type": "float",
                "DefaultValue": 0.0,
                "Category": "Movement"
            },
            {
                "Name": "MovementDirection",
                "Type": "FVector2D", 
                "DefaultValue": {"X": 0.0, "Y": 0.0},
                "Category": "Movement"
            },
            {
                "Name": "bIsInDanger",
                "Type": "bool",
                "DefaultValue": false,
                "Category": "Emotional State"
            },
            {
                "Name": "FearLevel",
                "Type": "float",
                "DefaultValue": 0.0,
                "Category": "Emotional State",
                "Range": {"Min": 0.0, "Max": 1.0}
            },
            {
                "Name": "StealthLevel",
                "Type": "float", 
                "DefaultValue": 0.0,
                "Category": "Movement State",
                "Range": {"Min": 0.0, "Max": 1.0}
            }
        ],
        
        "Functions": [
            {
                "Name": "UpdateMovementData",
                "Description": "Atualiza dados de movimento baseado no input do jogador",
                "Parameters": [
                    {"Name": "InputVector", "Type": "FVector2D"},
                    {"Name": "CharacterVelocity", "Type": "FVector"}
                ]
            },
            {
                "Name": "UpdateEmotionalState", 
                "Description": "Atualiza estado emocional baseado em ameaças próximas",
                "Parameters": [
                    {"Name": "NearbyThreats", "Type": "int32"},
                    {"Name": "ThreatDistance", "Type": "float"}
                ]
            }
        ]
    },
    
    "StateMachines": [
        {
            "Name": "Locomotion",
            "States": [
                {
                    "Name": "Idle",
                    "Animation": "Idle_Cautious",
                    "Transitions": [
                        {"To": "Walk", "Condition": "MovementSpeed > 0.1"},
                        {"To": "Crouch", "Condition": "StealthLevel > 0.5"}
                    ]
                },
                {
                    "Name": "Walk", 
                    "Animation": "Walk_Cautious",
                    "Transitions": [
                        {"To": "Idle", "Condition": "MovementSpeed < 0.1"},
                        {"To": "Run", "Condition": "MovementSpeed > 300.0"},
                        {"To": "Panic", "Condition": "bIsInDanger && FearLevel > 0.7"}
                    ]
                },
                {
                    "Name": "Run",
                    "Animation": "Run_Determined", 
                    "Transitions": [
                        {"To": "Walk", "Condition": "MovementSpeed < 250.0"},
                        {"To": "Panic", "Condition": "bIsInDanger && FearLevel > 0.8"}
                    ]
                },
                {
                    "Name": "Crouch",
                    "Animation": "Crouch_Stealth",
                    "Transitions": [
                        {"To": "Idle", "Condition": "StealthLevel < 0.3"},
                        {"To": "CrouchWalk", "Condition": "MovementSpeed > 0.1"}
                    ]
                },
                {
                    "Name": "CrouchWalk",
                    "Animation": "CrouchWalk_Stealth",
                    "Transitions": [
                        {"To": "Crouch", "Condition": "MovementSpeed < 0.1"},
                        {"To": "Walk", "Condition": "StealthLevel < 0.3"}
                    ]
                },
                {
                    "Name": "Panic",
                    "Animation": "Run_Panicked",
                    "Transitions": [
                        {"To": "Run", "Condition": "!bIsInDanger || FearLevel < 0.5"}
                    ]
                }
            ]
        }
    ]
}