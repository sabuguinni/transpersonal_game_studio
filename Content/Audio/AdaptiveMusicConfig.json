{
  "adaptive_music_config_version": "1.0",
  "agent": "Audio_Agent_16",
  "cycle": "PROD_CYCLE_AUTO_20260702_008",
  "description": "Adaptive music system configuration — MetaSounds-ready state machine for prehistoric survival game",
  "philosophy": "Music the player never notices consciously but that changes what they feel — RDR2 audio team principle",

  "state_machine": {
    "initial_state": "SAFE_DAY",
    "transition_rules": [
      {
        "from": "SAFE_DAY",
        "to": "EXPLORE_DAY",
        "condition": "player_distance_from_camp > 500 AND time_of_day == DAY",
        "transition_type": "crossfade",
        "crossfade_seconds": 4.0
      },
      {
        "from": "EXPLORE_DAY",
        "to": "PREDATOR_NEARBY",
        "condition": "nearest_predator_distance < 2000 AND player_not_spotted",
        "transition_type": "music_parameter_shift",
        "crossfade_seconds": 6.0
      },
      {
        "from": "PREDATOR_NEARBY",
        "to": "COMBAT_ACTIVE",
        "condition": "player_spotted == true OR player_health_delta < -10",
        "transition_type": "stinger_then_crossfade",
        "stinger_asset": "Stinger_CombatStart",
        "crossfade_seconds": 0.5
      },
      {
        "from": "COMBAT_ACTIVE",
        "to": "EXPLORE_DAY",
        "condition": "no_predators_within_3000 AND 30_seconds_elapsed",
        "transition_type": "fade_out_then_fade_in",
        "crossfade_seconds": 8.0
      },
      {
        "from": "EXPLORE_DAY",
        "to": "NIGHT_CAMP",
        "condition": "time_of_day == NIGHT AND player_near_campfire",
        "transition_type": "crossfade",
        "crossfade_seconds": 10.0
      },
      {
        "from": "NIGHT_CAMP",
        "to": "SAFE_DAY",
        "condition": "time_of_day == DAY AND player_rested",
        "transition_type": "crossfade",
        "crossfade_seconds": 8.0
      }
    ]
  },

  "music_layers": {
    "SAFE_DAY": {
      "base_layer": "Music_SafeDay_Base",
      "optional_layers": ["Music_SafeDay_BirdCall", "Music_SafeDay_WindPercussion"],
      "volume": 0.4,
      "pitch_variation": 0.02,
      "loop": true
    },
    "EXPLORE_DAY": {
      "base_layer": "Music_ExploreDay_Base",
      "optional_layers": ["Music_ExploreDay_Rhythm", "Music_ExploreDay_Tension_Low"],
      "volume": 0.55,
      "pitch_variation": 0.01,
      "loop": true
    },
    "PREDATOR_NEARBY": {
      "base_layer": "Music_Tension_Drone",
      "optional_layers": ["Music_Tension_Heartbeat", "Music_Tension_SparsePercussion"],
      "volume": 0.65,
      "pitch_variation": 0.0,
      "loop": true,
      "low_pass_filter_hz": 800,
      "reverb_wet_mix": 0.3
    },
    "COMBAT_ACTIVE": {
      "base_layer": "Music_Combat_Drums",
      "optional_layers": ["Music_Combat_BoneRattle", "Music_Combat_PrimalChant"],
      "volume": 0.85,
      "pitch_variation": 0.0,
      "loop": true,
      "compression_ratio": 4.0
    },
    "NIGHT_CAMP": {
      "base_layer": "Music_NightCamp_Ambient",
      "optional_layers": ["Music_NightCamp_InsectRhythm", "Music_NightCamp_DistantDrum"],
      "volume": 0.35,
      "pitch_variation": 0.03,
      "loop": true,
      "reverb_wet_mix": 0.5
    }
  },

