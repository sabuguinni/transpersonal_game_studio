{
  "MetaSoundSource": {
    "AssetType": "MetaSoundSource",
    "Version": "5.3",
    "Description": "Adaptive music system that responds to emotional states and threat levels",
    "Inputs": [
      {
        "Name": "EmotionalState",
        "Type": "Float",
        "DefaultValue": 0.0,
        "Description": "0=Calm, 1=Tension, 2=Danger, 3=Terror, 4=Relief, 5=Discovery, 6=Domestication"
      },
      {
        "Name": "ThreatLevel",
        "Type": "Float",
        "DefaultValue": 0.0,
        "Description": "0-1 threat intensity"
      },
      {
        "Name": "TimeOfDay",
        "Type": "Float",
        "DefaultValue": 2.0,
        "Description": "0=Dawn, 1=Morning, 2=Midday, 3=Afternoon, 4=Dusk, 5=Night, 6=DeepNight"
      },
      {
        "Name": "EnvironmentType",
        "Type": "Float",
        "DefaultValue": 0.0,
        "Description": "0=DenseForest, 1=OpenPlains, 2=RiverBanks, 3=Caves, 4=PlayerBase, 5=DinosaurTerritory"
      },
      {
        "Name": "StealthLevel",
        "Type": "Float",
        "DefaultValue": 1.0,
        "Description": "0-1 player stealth effectiveness"
      },
      {
        "Name": "DinosaurProximity",
        "Type": "Float",
        "DefaultValue": 0.0,
        "Description": "0-1 proximity to dangerous dinosaurs"
      }
    ],
    "Outputs": [
      {
        "Name": "OutLeft",
        "Type": "Audio"
      },
      {
        "Name": "OutRight",
        "Type": "Audio"
      }
    ],
    "Nodes": [
      {
        "Type": "WavePlayer",
        "Name": "BaseLayer_Calm",
        "WaveAsset": "/Content/Audio/Music/Stems/Base_Calm_Loop.wav",
        "Loop": true,
        "Volume": 0.7
      },
      {
        "Type": "WavePlayer", 
        "Name": "BaseLayer_Tension",
        "WaveAsset": "/Content/Audio/Music/Stems/Base_Tension_Loop.wav",
        "Loop": true,
        "Volume": 0.0
      },
      {
        "Type": "WavePlayer",
        "Name": "BaseLayer_Danger",
        "WaveAsset": "/Content/Audio/Music/Stems/Base_Danger_Loop.wav", 
        "Loop": true,
        "Volume": 0.0
      },
      {
        "Type": "WavePlayer",
        "Name": "PercussionLayer",
        "WaveAsset": "/Content/Audio/Music/Stems/Percussion_Adaptive.wav",
        "Loop": true,
        "Volume": 0.0
      },
      {
        "Type": "WavePlayer",
        "Name": "StringsLayer",
        "WaveAsset": "/Content/Audio/Music/Stems/Strings_Tension.wav",
        "Loop": true,
        "Volume": 0.0
      },
      {
        "Type": "LFO",
        "Name": "ThreatModulation",
        "Frequency": 0.1,
        "Shape": "Sine",
        "MinValue": 0.8,
        "MaxValue": 1.2
      },
      {
        "Type": "Crossfade",
        "Name": "EmotionalStateMixer",
        "Inputs": 3
      },
      {
        "Type": "Multiply",
        "Name": "ThreatLevelMod"
      },
      {
        "Type": "StereoMixer",
        "Name": "FinalMix"
      }
    ],
    "Connections": [
      {
        "From": "BaseLayer_Calm.Out",
        "To": "EmotionalStateMixer.In0"
      },
      {
        "From": "BaseLayer_Tension.Out", 
        "To": "EmotionalStateMixer.In1"
      },
      {
        "From": "BaseLayer_Danger.Out",
        "To": "EmotionalStateMixer.In2"
      },
      {
        "From": "EmotionalState",
        "To": "EmotionalStateMixer.CrossfadeValue"
      },
      {
        "From": "EmotionalStateMixer.Out",
        "To": "FinalMix.In0"
      },
      {
        "From": "PercussionLayer.Out",
        "To": "ThreatLevelMod.In0"
      },
      {
        "From": "ThreatLevel",
        "To": "ThreatLevelMod.In1"
      },
      {
        "From": "ThreatLevelMod.Out",
        "To": "FinalMix.In1"
      },
      {
        "From": "StringsLayer.Out",
        "To": "FinalMix.In2"
      },
      {
        "From": "FinalMix.OutLeft",
        "To": "OutLeft"
      },
      {
        "From": "FinalMix.OutRight",
        "To": "OutRight"
      }
    ]
  }
}