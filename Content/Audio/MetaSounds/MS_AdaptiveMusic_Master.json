{
  "MetaSoundName": "MS_AdaptiveMusic_Master",
  "Description": "Master adaptive music MetaSound for Jurassic Survival - responds to emotional states and threat levels",
  "Version": "1.0",
  "Inputs": [
    {
      "Name": "Intensity",
      "Type": "Float",
      "DefaultValue": 0.2,
      "Description": "Overall music intensity (0-1)"
    },
    {
      "Name": "Tension",
      "Type": "Float", 
      "DefaultValue": 0.1,
      "Description": "Musical tension level (0-1)"
    },
    {
      "Name": "ThreatLevel",
      "Type": "Float",
      "DefaultValue": 0.0,
      "Description": "Dinosaur threat presence (0-1)"
    },
    {
      "Name": "PlayerHeartRate",
      "Type": "Float",
      "DefaultValue": 60.0,
      "Description": "Simulated player heart rate (BPM)"
    },
    {
      "Name": "IsPlayerHidden",
      "Type": "Bool",
      "DefaultValue": false,
      "Description": "Whether player is hiding"
    },
    {
      "Name": "TransitionTime",
      "Type": "Float",
      "DefaultValue": 3.0,
      "Description": "Time to transition between states"
    },
    {
      "Name": "WeatherIntensity",
      "Type": "Float",
      "DefaultValue": 0.0,
      "Description": "Weather intensity affecting music"
    }
  ],
  "Outputs": [
    {
      "Name": "AudioLeft",
      "Type": "Audio"
    },
    {
      "Name": "AudioRight", 
      "Type": "Audio"
    }
  ],
  "NodeGraph": {
    "Description": "Adaptive music system with layered approach",
    "Layers": [
      {
        "Name": "BaseLayer",
        "Description": "Ambient drone and pad sounds",
        "Nodes": [
          {
            "Type": "WavePlayer",
            "WaveAsset": "Drone_Forest_Base_Loop",
            "Volume": "Intensity * 0.6"
          },
          {
            "Type": "LowFrequencyOscillator",
            "Frequency": "PlayerHeartRate / 60.0",
            "Shape": "Sine",
            "Amplitude": "Tension * 0.3"
          }
        ]
      },
      {
        "Name": "TensionLayer", 
        "Description": "Dissonant elements and stingers",
        "Nodes": [
          {
            "Type": "WavePlayer",
            "WaveAsset": "Tension_Strings_Loop",
            "Volume": "Tension * 0.8",
            "PitchShift": "ThreatLevel * 2.0"
          },
          {
            "Type": "RandomGet",
            "Array": ["Stinger_01", "Stinger_02", "Stinger_03"],
            "TriggerRate": "ThreatLevel * 0.5"
          }
        ]
      },
      {
        "Name": "PercussionLayer",
        "Description": "Rhythmic elements based on heart rate",
        "Nodes": [
          {
            "Type": "TriggerRepeat",
            "Period": "60.0 / PlayerHeartRate",
            "Volume": "Intensity * 0.4"
          },
          {
            "Type": "WavePlayer",
            "WaveAsset": "Heartbeat_Thump",
            "Volume": "ThreatLevel * 0.6"
          }
        ]
      },
      {
        "Name": "HiddenLayer",
        "Description": "Muffled sounds when player is hiding",
        "Nodes": [
          {
            "Type": "OnePoleHighPassFilter",
            "CutoffFrequency": "IsPlayerHidden ? 200.0 : 20.0"
          },
          {
            "Type": "OnePoleHighPassFilter", 
            "CutoffFrequency": "IsPlayerHidden ? 800.0 : 20000.0"
          }
        ]
      }
    ],
    "Mixing": {
      "MasterVolume": "0.7",
      "Compression": {
        "Ratio": "2.0",
        "Threshold": "-12.0",
        "AttackTime": "0.01",
        "ReleaseTime": "0.1"
      },
      "Reverb": {
        "WetLevel": "WeatherIntensity * 0.3",
        "RoomSize": "0.6"
      }
    }
  },
  "ParameterModulation": {
    "IntensitySmoothing": {
      "AttackTime": "TransitionTime * 0.3",
      "ReleaseTime": "TransitionTime * 0.7"
    },
    "TensionSmoothing": {
      "AttackTime": "TransitionTime * 0.2", 
      "ReleaseTime": "TransitionTime * 0.8"
    }
  }
}