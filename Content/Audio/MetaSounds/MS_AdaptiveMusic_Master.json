{
  "MetaSoundType": "Source",
  "Name": "MS_AdaptiveMusic_Master",
  "Description": "Sistema de música adaptativa principal que responde ao estado emocional do jogador e proximidade de dinossauros",
  "Version": "1.0",
  "Inputs": [
    {
      "Name": "Intensity",
      "Type": "Float",
      "DefaultValue": 0.3,
      "Description": "Intensidade geral da música (0.0 = calma, 1.0 = máxima tensão)"
    },
    {
      "Name": "TensionLevel",
      "Type": "Float", 
      "DefaultValue": 0.0,
      "Description": "Nível de tensão baseado na proximidade de dinossauros"
    },
    {
      "Name": "ProximityThreat",
      "Type": "Float",
      "DefaultValue": 0.0,
      "Description": "Ameaça de proximidade de predadores"
    },
    {
      "Name": "PlayerHidden",
      "Type": "Bool",
      "DefaultValue": false,
      "Description": "Se o jogador está escondido/agachado"
    },
    {
      "Name": "TimeOfDay",
      "Type": "Float",
      "DefaultValue": 0.5,
      "Description": "Hora do dia (0.0 = meia-noite, 0.5 = meio-dia, 1.0 = meia-noite)"
    },
    {
      "Name": "EnvironmentType",
      "Type": "Int32",
      "DefaultValue": 0,
      "Description": "Tipo de ambiente (0=Floresta, 1=Planícies, 2=Rios, etc.)"
    }
  ],
  "Outputs": [
    {
      "Name": "Audio Out L",
      "Type": "Audio"
    },
    {
      "Name": "Audio Out R", 
      "Type": "Audio"
    }
  ],
  "Graph": {
    "Nodes": [
      {
        "Type": "WavePlayer",
        "Name": "BaseLayer_Exploration",
        "Position": {"X": 100, "Y": 100},
        "Inputs": {
          "WaveAsset": "/Content/Audio/Music/Layers/Base_Exploration_Loop.wav",
          "Loop": true,
          "Volume": 0.7
        }
      },
      {
        "Type": "WavePlayer", 
        "Name": "TensionLayer_Low",
        "Position": {"X": 100, "Y": 200},
        "Inputs": {
          "WaveAsset": "/Content/Audio/Music/Layers/Tension_Low_Loop.wav",
          "Loop": true,
          "Volume": 0.0
        }
      },
      {
        "Type": "WavePlayer",
        "Name": "TensionLayer_High", 
        "Position": {"X": 100, "Y": 300},
        "Inputs": {
          "WaveAsset": "/Content/Audio/Music/Layers/Tension_High_Loop.wav",
          "Loop": true,
          "Volume": 0.0
        }
      },
      {
        "Type": "WavePlayer",
        "Name": "DangerLayer_Stingers",
        "Position": {"X": 100, "Y": 400},
        "Inputs": {
          "WaveAsset": "/Content/Audio/Music/Layers/Danger_Stingers.wav",
          "Loop": false,
          "Volume": 0.0
        }
      },
      {
        "Type": "Crossfade",
        "Name": "TensionCrossfade",
        "Position": {"X": 400, "Y": 250},
        "Inputs": {
          "NumInputs": 3
        }
      },
      {
        "Type": "Multiply",
        "Name": "IntensityModulator",
        "Position": {"X": 600, "Y": 200}
      },
      {
        "Type": "LowPassFilter",
        "Name": "HiddenFilter",
        "Position": {"X": 800, "Y": 200},
        "Inputs": {
          "CutoffFrequency": 20000.0
        }
      },
      {
        "Type": "Reverb",
        "Name": "EnvironmentReverb",
        "Position": {"X": 1000, "Y": 200},
        "Inputs": {
          "WetLevel": 0.2,
          "RoomSize": 0.5
        }
      },
      {
        "Type": "StereoMixer",
        "Name": "FinalMix",
        "Position": {"X": 1200, "Y": 200}
      }
    ],
    "Connections": [
      {
        "From": "BaseLayer_Exploration.Audio",
        "To": "TensionCrossfade.In0"
      },
      {
        "From": "TensionLayer_Low.Audio", 
        "To": "TensionCrossfade.In1"
      },
      {
        "From": "TensionLayer_High.Audio",
        "To": "TensionCrossfade.In2"
      },
      {
        "From": "TensionLevel",
        "To": "TensionCrossfade.CrossfadeValue"
      },
      {
        "From": "TensionCrossfade.Out",
        "To": "IntensityModulator.In"
      },
      {
        "From": "Intensity",
        "To": "IntensityModulator.Multiplier"
      },
      {
        "From": "IntensityModulator.Out",
        "To": "HiddenFilter.In"
      },
      {
        "From": "HiddenFilter.Out",
        "To": "EnvironmentReverb.In"
      },
      {
        "From": "EnvironmentReverb.Out",
        "To": "FinalMix.In L"
      },
      {
        "From": "EnvironmentReverb.Out",
        "To": "FinalMix.In R"
      },
      {
        "From": "FinalMix.Out L",
        "To": "Audio Out L"
      },
      {
        "From": "FinalMix.Out R", 
        "To": "Audio Out R"
      }
    ],
    "ParameterMappings": [
      {
        "Parameter": "PlayerHidden",
        "Target": "HiddenFilter.CutoffFrequency",
        "Mapping": "MapRange",
        "InputRange": [false, true],
        "OutputRange": [20000.0, 8000.0]
      },
      {
        "Parameter": "EnvironmentType",
        "Target": "EnvironmentReverb.RoomSize",
        "Mapping": "Select",
        "Values": [0.3, 0.8, 0.5, 0.9, 0.1, 0.4]
      },
      {
        "Parameter": "ProximityThreat",
        "Target": "DangerLayer_Stingers.TriggerProbability",
        "Mapping": "MapRange",
        "InputRange": [0.0, 1.0],
        "OutputRange": [0.0, 0.8]
      }
    ]
  }
}