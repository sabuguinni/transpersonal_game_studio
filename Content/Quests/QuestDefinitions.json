{
  "quest_database_version": "1.0.0",
  "game": "Transpersonal Survival — Cretaceous",
  "quests": [
    {
      "quest_id": "QUEST_001",
      "title": "Silent Observer",
      "type": "observation",
      "difficulty": "tutorial",
      "giver_actor": "NPC_Elder_QuestGiver_001",
      "trigger_actor": "QuestTrigger_SilentObserver_001",
      "description": "Approach the Triceratops herd within 500 units without running or making sudden movements. Observe their grazing patterns for 30 seconds.",
      "objectives": [
        {
          "id": "OBJ_001_A",
          "type": "approach_without_running",
          "target_actor_tag": "Herd_Triceratops",
          "required_distance_units": 500,
          "player_speed_constraint": "walk_only",
          "description": "Approach the Triceratops herd while walking"
        },
        {
          "id": "OBJ_001_B",
          "type": "observe_duration",
          "target_actor_tag": "Herd_Triceratops",
          "duration_seconds": 30,
          "max_player_speed": 200,
          "description": "Observe the herd for 30 seconds without disturbing them"
        }
      ],
      "rewards": {
        "experience": 100,
        "knowledge_unlock": "Triceratops Behavior",
        "crafting_recipe_unlock": "Camouflage_Mud_Pack"
      },
      "failure_conditions": [
        "player_runs_within_800u_of_herd",
        "herd_flee_behavior_triggered",
        "player_attacks_any_herd_member"
      ],
      "dialogue": {
        "intro_audio": "https://thdlkizjbpwdndtggleb.supabase.co/storage/v1/object/public/game-assets/tts/1783080668646_Elder_QuestGiver.mp3",
        "completion_audio": "https://thdlkizjbpwdndtggleb.supabase.co/storage/v1/object/public/game-assets/tts/1783080695027_Elder_QuestGiver.mp3",
        "intro_text": "Listen carefully. The great horned ones graze near the water. Do not startle them. Move slow, stay low, and watch how they move together. If you learn their patterns, you will know when the predators come. This is your first lesson in survival.",
        "completion_text": "You did it. You stood among the giants and they did not flee. Few survive long enough to learn this. The herd trusts stillness. Remember that when the ground shakes and the horns lower — because the next lesson will not be so peaceful."
      },
      "world_markers": {
        "trigger_volume": "QuestTrigger_SilentObserver_001",
        "herd_actors": ["Trike_Savana_001", "Trike_Savana_002", "Trike_Savana_003", "Trike_Savana_004", "Trike_Savana_005", "Trike_Savana_006"]
      }
    },
    {
      "quest_id": "QUEST_002",
      "title": "The Long Neck Trail",
      "type": "tracking",
      "difficulty": "easy",
      "giver_actor": "NPC_Elder_QuestGiver_001",
      "prerequisite_quest": "QUEST_001",
      "description": "Follow the Brachiosaurus herd as they migrate north. Discover what lies beyond the tree line.",
      "objectives": [
        {
          "id": "OBJ_002_A",
          "type": "reach_waypoint",
          "target_actor": "QuestMarker_LongNeckTrail_001",
          "description": "Follow the Brachiosaurus herd north to the waypoint"
        },
        {
          "id": "OBJ_002_B",
          "type": "observe_duration",
          "target_actor_tag": "Herd_Brachiosaurus",
          "duration_seconds": 20,
          "description": "Observe the Brachiosaurus browsing behavior for 20 seconds"
        },
        {
          "id": "OBJ_002_C",
          "type": "discover_area",
          "area_tag": "NorthernForest",
          "description": "Explore the northern forest biome revealed by following the herd"
        }
      ],
      "rewards": {
        "experience": 200,
        "knowledge_unlock": "Brachiosaurus Migration Patterns",
        "map_area_unlock": "Northern Forest"
      },
      "failure_conditions": [
        "player_attacks_any_herd_member",
        "player_leaves_tracking_zone_for_60s"
      ],
      "world_markers": {
        "waypoint_1": "QuestMarker_LongNeckTrail_001",
        "herd_actors": ["Brach_Floresta_001", "Brach_Floresta_002", "Brach_Floresta_003"]
      }
    },
    {
      "quest_id": "QUEST_003",
      "title": "Stampede Survival",
      "type": "survival_event",
      "difficulty": "medium",
      "giver_actor": "NPC_Elder_QuestGiver_001",
      "prerequisite_quest": "QUEST_001",
      "description": "A predator has entered the grazing grounds. The Triceratops herd is panicking. Survive the stampede and drive away the threat.",
      "objectives": [
        {
          "id": "OBJ_003_A",
          "type": "survive_duration",
          "duration_seconds": 60,
          "hazard_tag": "Stampede_Active",
          "description": "Survive 60 seconds of stampede chaos without being trampled"
        },
        {
          "id": "OBJ_003_B",
          "type": "reach_safe_zone",
          "target_actor": "QuestTrigger_StampedeZone_001",
          "description": "Reach the high ground safe zone east of the herd"
        },
        {
          "id": "OBJ_003_C",
          "type": "drive_away_predator",
          "target_actor_tag": "Predator_Raptor",
          "method": "fire_or_noise",
          "description": "Drive the raptor away using fire or loud noise"
        }
      ],
      "rewards": {
        "experience": 350,
        "knowledge_unlock": "Stampede Behavior",
        "crafting_recipe_unlock": "Fire_Torch"
      },
      "failure_conditions": [
        "player_health_reaches_zero",
        "player_trampled_3_times"
      ],
      "world_markers": {
        "trigger_volume": "QuestTrigger_StampedeZone_001",
        "safe_zone": "QuestMarker_StampedeSafeZone_001"
      }
    },
