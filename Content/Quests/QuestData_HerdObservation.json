{
  "quest_id": "QUEST_HERD_OBSERVATION_001",
  "quest_name": "Observe the Herd",
  "quest_type": "SCOUTING",
  "difficulty": "EASY",
  "giver_actor": "Elder_NPC_QuestGiver_001",
  "description": "The Elder needs a count of the Triceratops herd before the tribe plans its next hunt. Approach the grazing grounds without startling the animals, observe the herd composition, then return safely.",
  "lore_context": "Triceratops herds migrate with the wet season. Knowing the herd size and the number of calves tells the tribe how much meat is available and how dangerous the hunt will be.",
  "objectives": [
    {
      "id": "OBJ_01",
      "type": "REACH_ZONE",
      "description": "Travel to the Triceratops grazing grounds",
      "target_actor": "QuestZone_HerdObserve_001",
      "required": true,
      "order": 1
    },
    {
      "id": "OBJ_02",
      "type": "OBSERVE_ACTORS",
      "description": "Count the Triceratops in the herd (observe 5 or more)",
      "target_class": "Triceratops",
      "required_count": 5,
      "required": true,
      "order": 2,
      "mechanic_note": "Player must remain within 800 units of each Triceratops for 3 seconds without triggering alert state"
    },
    {
      "id": "OBJ_03",
      "type": "OPTIONAL_OBSERVE",
      "description": "Count the calves separately (optional — increases reward)",
      "target_tag": "Triceratops_Calf",
