      "objectives": [
        {
          "id": "OBJ_002_A",
          "type": "collect",
          "description": "Gather 3 Sticks",
          "resource": "Resource_Stick",
          "quantity": 3,
          "map_actors": ["Resource_Stick_001", "Resource_Stick_002", "Resource_Stick_003"]
