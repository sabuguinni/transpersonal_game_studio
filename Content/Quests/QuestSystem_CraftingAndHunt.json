          "recipe": "Campfire",
          "location_actor": "QuestMarker_Campfire_001",
          "trigger_key": "C"
        },
        {
          "id": "OBJ_002_C",
          "type": "survive",
          "description": "Survive until dawn at the campfire",
          "duration_seconds": 120,
          "condition": "stay_within_radius",
          "radius": 500,
          "center_actor": "QuestMarker_Campfire_001"
        }
      ],
      "rewards": {
        "xp": 150,
        "items": ["Campfire"],
        "unlocks": ["QUEST_003_WATER"]
      },
      "npc_voice": {
        "character": "QuestNPC_Scout",
        "audio_url": "https://thdlkizjbpwdndtggleb.supabase.co/storage/v1/object/public/game-assets/tts/1781810602766_QuestNPC_Scout.mp3",
        "line": "The T-Rex has been spotted near the eastern ridge. Its tracks lead north. Follow them carefully — stay downwind, move slow, and do not run until you are ready to strike."
      }
    },
    {
      "id": "QUEST_003_WATER",
      "title": "Find Water",
      "description": "Locate the water source and craft a water container before dehydration sets in.",
      "arc": "Survival — thirst is the silent killer. The player learns resource scarcity.",
      "objectives": [
        {
          "id": "OBJ_003_A",
          "type": "navigate",
          "description": "Find the water source",
          "marker_actor": "QuestMarker_WaterSource_001",
          "position": {"x": 800, "y": -1200, "z": 80}
        },
        {
          "id": "OBJ_003_B",
          "type": "collect",
