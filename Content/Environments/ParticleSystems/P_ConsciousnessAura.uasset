// Particle System for Consciousness Aura Effects
// Responds to player consciousness states with different visual patterns

Begin Object Class=/Script/Engine.ParticleSystem Name="P_ConsciousnessAura"
   
   // Emitter 0: Base Aura Particles
   Emitters(0)=ParticleEmitter'"ParticleEmitter_0"'
   {
      EmitterName="BaseAura"
      
      // Spawn Module
      SpawnRate=50.0
      SpawnRateScale=1.0
      
      // Lifetime Module  
      Lifetime=5.0
      LifetimeRandomness=2.0
      
      // Size Module
      StartSize=(X=0.1,Y=0.1,Z=0.1)
      StartSizeRandomness=(X=0.05,Y=0.05,Z=0.05)
      SizeScale=(X=2.0,Y=2.0,Z=2.0)
      
      // Color Module
      StartColor=(R=1.0,G=1.0,B=1.0,A=0.3)
      ColorOverLife=True
      ColorScale=(R=1.0,G=0.8,B=0.6,A=0.0) // Fade to warm tone
      
      // Velocity Module
      StartVelocity=(X=0.0,Y=0.0,Z=50.0)
      VelocityRandomness=(X=20.0,Y=20.0,Z=10.0)
      
      // Location Module
      StartLocation=(X=0.0,Y=0.0,Z=0.0)
      LocationRandomness=(X=100.0,Y=100.0,Z=50.0)
      
      // Material
      Material=/Game/Environments/Materials/M_ParticleAura
      
      // Consciousness Response Parameters
      ParameterName="ConsciousnessLevel" DefaultValue=0.5
      ParameterName="EmotionalResonance" DefaultValue=0.0  
      ParameterName="SpiritualAlignment" DefaultValue=0.0
   }
   
   // Emitter 1: Energy Streams
   Emitters(1)=ParticleEmitter'"ParticleEmitter_1"'
   {
      EmitterName="EnergyStreams"
      
      SpawnRate=20.0
      Lifetime=8.0
      
      StartSize=(X=0.05,Y=0.05,Z=0.05)
      SizeScale=(X=5.0,Y=5.0,Z=5.0)
      
      StartColor=(R=0.5,G=0.8,B=1.0,A=0.5)
      
      StartVelocity=(X=0.0,Y=0.0,Z=100.0)
      VelocityRandomness=(X=30.0,Y=30.0,Z=20.0)
      
      // Orbital movement around player
      OrbitModule=True
      OrbitRadius=200.0
      OrbitSpeed=45.0
      
      Material=/Game/Environments/Materials/M_ParticleStream
   }
   
   // Emitter 2: Transcendent Light
   Emitters(2)=ParticleEmitter'"ParticleEmitter_2"'
   {
      EmitterName="TranscendentLight"
      
      SpawnRate=10.0
      Lifetime=10.0
      
      StartSize=(X=0.2,Y=0.2,Z=0.2)
      SizeScale=(X=10.0,Y=10.0,Z=10.0)
      
      StartColor=(R=1.0,G=1.0,B=1.0,A=0.8)
      
      StartVelocity=(X=0.0,Y=0.0,Z=20.0)
      
      // Only active during transcendent states
      ConditionalSpawn=True
      SpawnCondition="SpiritualAlignment > 0.7"
      
      Material=/Game/Environments/Materials/M_ParticleLight
   }
   
End Object