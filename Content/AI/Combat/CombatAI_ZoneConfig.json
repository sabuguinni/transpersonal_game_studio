      },
      "sensory_system": {
        "sight_range_units": 2500,
        "sight_fov_degrees": 45,
        "smell_range_units": 3000,
        "wind_direction_affects_smell": true,
        "hearing_range_units": 1800,
        "movement_detection_multiplier": 2.0,
        "stillness_detection_reduction": 0.1,
        "night_sight_penalty": 0.4
