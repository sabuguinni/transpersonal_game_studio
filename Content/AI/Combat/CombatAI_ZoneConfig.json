    "combat_voice_lines": {
      "CombatNarrator_TRex": {
        "url": "https://thdlkizjbpwdndtggleb.supabase.co/storage/v1/object/public/game-assets/tts/1781830037600_CombatNarrator.mp3",
        "text": "It's charging. Don't run — you cannot outrun it. Drop flat, press against the ground, stay still. It hunts by movement. If it loses sight of you, it will circle. Wait for it to turn its back. That is your only window to escape.",
        "trigger": "TRex_CHASE_state_entered",
        "cooldown_seconds": 120
      },
      "CombatNarrator_Raptor": {
        "url": "https://thdlkizjbpwdndtggleb.supabase.co/storage/v1/object/public/game-assets/tts/1781830064185_CombatNarrator_Raptor.mp3",
        "text": "The raptors are coordinating. One is circling left, one right — they're trying to flank you. Get your back against something solid. A tree, a rock face, anything. Force them to come at you from the front. They lose their advantage if they can't surround you.",
        "trigger": "Raptor_PINCER_state_entered",
        "cooldown_seconds": 90
      }
