    "raptor_pack_combat_system": {
      "species": "Velociraptor",
      "pack_size": { "min": 2, "max": 4 },
      "ai_states": {
        "STALK": {
          "description": "Pack spreading to flank positions. Triggered at CombatZone_Raptor_StalkTrigger_001 (800u)",
          "trigger_range_units": 800,
          "trigger_zone_marker": "CombatZone_Raptor_StalkTrigger_001",
          "stalk_speed": 120,
          "stalk_animation": "Raptor_Crouch_Stalk",
          "flank_positions": {
            "left_flank": "CombatZone_Raptor_FlankLeft_001",
            "right_flank": "CombatZone_Raptor_FlankRight_001",
            "center_distract": "BTZone_Raptor_Ambush_001"
          },
          "coordination": "alpha_signals_when_all_in_position",
          "transition_to_PINCER": "all_raptors_in_flank_positions"
        },
        "PINCER": {
          "description": "Coordinated pincer — left+right close simultaneously while center distracts",
