          "attack_rotation_seconds": 1.5,
          "damage_per_raptor_hit": 35,
          "knockdown_chance": 0.4,
          "escape_condition": "player_reaches_high_ground OR kills_2_raptors",
          "pack_retreat_on_loss": true
        },
        "RETREAT": {
          "description": "Pack retreats if 2+ members killed or player reaches high ground",
          "retreat_trigger": "pack_size_below_2 OR player_elevation_above_400u",
          "retreat_speed": 500,
          "regroup_distance_units": 2000,
          "regroup_cooldown_seconds": 45
        }
      },
      "pack_coordination": {
        "alpha_raptor": "first_spawned_in_pack",
        "communication_range_units": 1200,
        "pack_signal_type": "vocalisation_bark",
        "independent_hunt_if_separated": true
