          "attack_animation": "TRex_Bite_Lunge",
          "damage_per_hit": 85,
          "knockback_force": 1200,
          "attack_cooldown_seconds": 2.5,
          "transition_to_CHASE": "player_escapes_300u_range"
        },
        "TERRITORIAL": {
          "description": "Defending kill or nest — heightened aggression, no retreat",
          "aggro_range_multiplier": 1.5,
          "damage_multiplier": 1.3,
          "trigger_condition": "player_near_active_kill_site"
