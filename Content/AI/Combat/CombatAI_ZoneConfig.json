      "sensory_system": {
        "sight_range_units": 1500,
        "sight_fov_degrees": 120,
        "smell_range_units": 800,
        "hearing_range_units": 1200,
        "dusk_hunt_bonus": 1.4,
        "pack_detection_sharing": true
      }
    },

