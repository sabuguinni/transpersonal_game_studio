{
    "Type": "BehaviorTree",
    "Name": "BT_DinosaurCombat",
    "Description": "Main behavior tree for dinosaur combat AI",
    "BlackboardAsset": "/Game/AI/Combat/BB_DinosaurCombat",
    "RootNode": {
        "Type": "Selector",
        "Children": [
            {
                "Type": "Sequence",
                "Name": "Emergency Flee",
                "Decorators": [
                    {
                        "Type": "Blackboard",
                        "KeyName": "ShouldFlee",
                        "KeyType": "Bool",
                        "Operation": "EqualTo",
                        "Value": true
                    }
                ],
                "Children": [
                    {
                        "Type": "Task",
                        "TaskType": "RunEQSQuery",
                        "QueryTemplate": "/Game/AI/Combat/EQS_FleePosition",
                        "BlackboardKey": "FleeLocation",
                        "RunMode": "SingleBestItem"
                    },
                    {
                        "Type": "Task",
                        "TaskType": "MoveTo",
                        "BlackboardKey": "FleeLocation",
                        "AcceptableRadius": 100.0,
                        "AllowStrafe": true
                    }
                ]
            },
            {
                "Type": "Sequence",
                "Name": "Combat Sequence",
                "Decorators": [
                    {
                        "Type": "Blackboard",
                        "KeyName": "TargetActor",
                        "KeyType": "Object",
                        "Operation": "IsSet"
                    }
                ],
                "Children": [
                    {
                        "Type": "Selector",
                        "Name": "Combat Actions",
                        "Children": [
                            {
                                "Type": "Sequence",
                                "Name": "Attack Sequence",
                                "Decorators": [
                                    {
                                        "Type": "Distance",
                                        "DistanceType": "Distance3D",
                                        "BlackboardKeyA": "SelfActor",
                                        "BlackboardKeyB": "TargetActor",
                                        "ComparisonType": "LessOrEqual",
                                        "FloatValue": 300.0
                                    }
                                ],
                                "Children": [
                                    {
                                        "Type": "Task",
                                        "TaskType": "RotateToFaceBBEntry",
                                        "BlackboardKey": "TargetActor",
                                        "Precision": 10.0
                                    },
                                    {
                                        "Type": "Task",
                                        "TaskType": "Wait",
                                        "WaitTime": 0.5,
                                        "RandomDeviation": 0.2
                                    },
                                    {
                                        "Type": "Task",
                                        "TaskType": "PlayAnimation",
                                        "AnimationAsset": "/Game/Dinosaurs/Animations/Attack_Bite",
                                        "Looping": false,
                                        "NonBlocking": false
                                    }
                                ]
                            },
                            {
                                "Type": "Sequence",
                                "Name": "Hunt Sequence",
                                "Children": [
                                    {
                                        "Type": "Task",
                                        "TaskType": "RunEQSQuery",
                                        "QueryTemplate": "/Game/AI/Combat/EQS_OptimalAttackPosition",
                                        "BlackboardKey": "OptimalPosition",
                                        "RunMode": "SingleBestItem"
                                    },
                                    {
                                        "Type": "Task",
                                        "TaskType": "MoveTo",
                                        "BlackboardKey": "OptimalPosition",
                                        "AcceptableRadius": 150.0,
                                        "AllowStrafe": true,
                                        "TrackMovingGoal": true
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "Type": "Sequence",
                "Name": "Patrol Sequence",
                "Children": [
                    {
                        "Type": "Task",
                        "TaskType": "RunEQSQuery",
                        "QueryTemplate": "/Game/AI/Combat/EQS_PatrolPoint",
                        "BlackboardKey": "PatrolLocation",
                        "RunMode": "SingleRandomItemFromBest25Pct"
                    },
                    {
                        "Type": "Task",
                        "TaskType": "MoveTo",
                        "BlackboardKey": "PatrolLocation",
                        "AcceptableRadius": 200.0,
                        "AllowStrafe": false
                    },
                    {
                        "Type": "Task",
                        "TaskType": "Wait",
                        "WaitTime": 3.0,
                        "RandomDeviation": 2.0
                    }
                ]
            }
        ]
    },
    "Services": [
        {
            "Type": "Service",
            "ServiceType": "ThreatAssessment",
            "Interval": 0.5,
            "AttachedTo": "RootNode"
        }
    ]
}